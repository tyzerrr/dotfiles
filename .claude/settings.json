{
  "permissions": {
    "allow": [
      "Bash(gh pr list)",
      "Bash(gh pr view)",
      "Bash(gh pr diff)",
      "Bash(gh pr checks)",
      "Bash(gh run view)",
      "mcp__github__get_*",
      "mcp__github__list_*",
      "mcp__github__search_*",
      "mcp__github__pull_request_read",
      "mcp__github__issue_read",
      "ReadMcpResourceTool(server=github)",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "mcp__atlassian-mcp-server__get*",
      "mcp__atlassian-mcp-server__search*",
      "mcp__atlassian-mcp-server__fetch",
      "mcp__atlassian-mcp-server__lookupJiraAccountId",
      "mcp__atlassian-mcp-server__atlassianUserInfo",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-search",
      "mcp__notion__notion-get-*",
      "mcp__notion__notion-query-*",
      "mcp__mcp-obsidian__obsidian_read*",
      "mcp__mcp-obsidian__obsidian_search*",
      "mcp__mcp-obsidian__obsidian_global_search*",
      "mcp__mcp-obsidian__obsidian_list*",
      "Bash(uv run ruff)",
      "Bash(uv run mypy)",
      "Bash(uv run tox)",
      "Bash(uv run pytest)",
      "Bash(go test)",
      "Bash(go build)",
      "Read",
      "Grep",
      "Glob"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] idle_prompt hook triggered\" >> /tmp/claude-hooks.log && ~/.config/zsh/claude-notify.sh '入力を待っています'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] Stop hook triggered\" >> /tmp/claude-hooks.log && ~/.config/zsh/claude-notify.sh 'タスクが完了しました'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "vercel@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
